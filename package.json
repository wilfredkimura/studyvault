{
  "name": "studyvault",
  "version": "1.0.0",
  "description": "Offline-first academic document system with optional AI enhancements",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "tsc -p tsconfig.main.json && electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "academic",
    "document",
    "vault",
    "pdf",
    "ocr",
    "local-first",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
